{
  "_meta": {
    "description": "Test scenarios for POST /api/lite/airtable-reprocess (AX07 pipeline)",
    "usage": "curl -X POST http://localhost:3000/api/lite/airtable-reprocess -H 'Content-Type: application/json' -d @scripts/test-scenarios-ax07.json (pipe individual scenario via jq '.scenarios.strong_funding')",
    "notes": [
      "Snapshot-based payloads have no raw tradeline data — utilization defaults to 'unknown' band.",
      "Because utilization band is never 'excellent' or 'good' from snapshots, isFullStack() cannot pass. Clean files land in CONDITIONAL_APPROVAL.",
      "Business boost requires bs.available (set by derive-business-signals, NOT by buildBusinessSignalsFromSnapshot), so business boost will not fire through this endpoint."
    ]
  },

  "scenarios": {
    "strong_funding": {
      "_expected": "CONDITIONAL_APPROVAL (utilization band 'unknown' from snapshots prevents FULL_STACK; clean file, no derogs)",
      "source": "airtable-ax07",
      "client": { "email": "test-strong@fundhub.ai" },
      "round": { "underwriteiq_reference_id": "ref-strong-001" },
      "submitted_form": { "full_name": "MARCUS JOHNSON" },
      "consumer_reports": [
        { "bureau": "TU", "score": 750, "inquiry_count": 0, "derog_count": 0, "late_count": 0 },
        { "bureau": "EX", "score": 740, "inquiry_count": 0, "derog_count": 0, "late_count": 0 },
        { "bureau": "EQ", "score": 760, "inquiry_count": 0, "derog_count": 0, "late_count": 0 }
      ],
      "business_report": {
        "business_score": 85,
        "recommended_limit": 75000,
        "ucc_count": 1,
        "public_records_count": 0,
        "payment_summary": "Satisfactory payment history across 12 tradelines",
        "payment_stress": "Low",
        "fraud_flag": "Unknown",
        "major_fraud_alert": ""
